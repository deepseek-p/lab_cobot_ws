<?xml version="1.0"?>
<!--
  一体化麦轮移动机械臂:麦轮全向底盘 + 基座立柱 + UR5e + 平行夹爪 + 传感器。
  UR5e 用官方 ur_description 的 ur_robot macro(sim_gazebo 模式),装在立柱顶 arm_mount_link。
  关节由 gazebo_ros2_control 驱动;底盘车体运动由 lab_cobot_mecanum_drive 的
  位姿积分模型(pose_from_wheel_commands,逐 tick SetWorldPose)施加,
  轮关节旋转仅为视觉同步,不参与推进。
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="lab_cobot">

  <!-- ===== 全局尺寸(供各部件宏引用) ===== -->
  <!-- 底盘加宽加长(0.55x0.50):增大支撑多边形,显著提高抗倾覆 -->
  <xacro:property name="base_length"  value="0.55"/>
  <xacro:property name="base_width"   value="0.50"/>
  <xacro:property name="base_height"  value="0.15"/>
  <xacro:property name="wheel_radius" value="0.08"/>
  <xacro:property name="wheel_width"  value="0.05"/>

  <!-- ===== 部件宏 ===== -->
  <xacro:include filename="$(find lab_cobot_description)/urdf/inc/common.xacro"/>
  <xacro:include filename="$(find lab_cobot_description)/urdf/inc/mecanum_base.xacro"/>
  <xacro:include filename="$(find lab_cobot_description)/urdf/inc/pillar.xacro"/>
  <xacro:include filename="$(find lab_cobot_description)/urdf/inc/sensors.xacro"/>
  <xacro:include filename="$(find lab_cobot_description)/urdf/inc/wrist_camera.xacro"/>
  <xacro:include filename="$(find lab_cobot_description)/urdf/inc/parallel_gripper.xacro"/>

  <!-- ===== UR5e 参数 ===== -->
  <xacro:arg name="ur_type" default="ur5e"/>
  <xacro:arg name="tf_prefix" default="ur_"/>
  <xacro:arg name="joint_limit_params" default="$(find ur_description)/config/$(arg ur_type)/joint_limits.yaml"/>
  <xacro:arg name="kinematics_params" default="$(find ur_description)/config/$(arg ur_type)/default_kinematics.yaml"/>
  <xacro:arg name="physical_params" default="$(find ur_description)/config/$(arg ur_type)/physical_parameters.yaml"/>
  <xacro:arg name="visual_params" default="$(find ur_description)/config/$(arg ur_type)/visual_parameters.yaml"/>
  <xacro:arg name="initial_positions_file" default="$(find lab_cobot_description)/config/initial_positions.yaml"/>
  <xacro:arg name="simulation_controllers" default="$(find lab_cobot_description)/config/lab_cobot_controllers.yaml"/>
  <xacro:arg name="require_finger_contact" default="false"/>
  <xacro:arg name="gazebo_tactile_probe" default="false"/>
  <xacro:arg name="enable_contact_force" default="false"/>
  <xacro:arg name="enable_lab_sensors" default="true"/>
  <xacro:arg name="wrist_refine_camera" default="false"/>
  <xacro:property name="initial_positions_file" default="$(arg initial_positions_file)"/>

  <xacro:include filename="$(find ur_description)/urdf/ur_macro.xacro"/>

  <!-- ===== 组装:底盘 → 立柱 → 传感器 ===== -->
  <!-- base_mass 加重以压低重心；Gazebo Classic 麦轮接触仍为近似模型。 -->
  <xacro:mecanum_base base_mass="180.0"/>
  <!-- 立柱降低(0.30)以降低臂安装点与整机重心;仍足够 UR5e 够到 0.75 桌面 -->
  <xacro:base_pillar parent="base_link" column_height="0.30"/>
  <xacro:if value="$(arg enable_lab_sensors)">
    <xacro:lab_sensors/>
  </xacro:if>

  <!-- ===== UR5e(装在立柱顶 arm_mount_link;Gazebo 仿真) ===== -->
  <xacro:ur_robot
    name="$(arg ur_type)"
    tf_prefix="$(arg tf_prefix)"
    parent="arm_mount_link"
    joint_limits_parameters_file="$(arg joint_limit_params)"
    kinematics_parameters_file="$(arg kinematics_params)"
    physical_parameters_file="$(arg physical_params)"
    visual_parameters_file="$(arg visual_params)"
    transmission_hw_interface=""
    safety_limits="false"
    safety_pos_margin="0.15"
    safety_k_position="20"
    use_fake_hardware="false"
    fake_sensor_commands="false"
    sim_gazebo="true"
    sim_ignition="false"
    headless_mode="false"
    initial_positions="${xacro.load_yaml(initial_positions_file)}"
    use_tool_communication="false"
    tool_voltage="0"
    tool_parity="0"
    tool_baud_rate="115200"
    tool_stop_bits="1"
    tool_rx_idle_chars="1.5"
    tool_tx_idle_chars="3.5"
    tool_device_name="/tmp/ttyUR"
    tool_tcp_port="54321"
    robot_ip="0.0.0.0"
    script_filename=""
    output_recipe_filename=""
    input_recipe_filename=""
    reverse_ip="0.0.0.0"
    script_command_port="50004"
    reverse_port="50001"
    script_sender_port="50002"
    trajectory_port="50003"
    >
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </xacro:ur_robot>

  <!-- ===== Parallel gripper mounted on UR tool0 ===== -->
  <xacro:parallel_gripper
    parent="ur_tool0"
    gazebo_tactile_probe="$(arg gazebo_tactile_probe)"/>
  <xacro:if value="$(arg wrist_refine_camera)">
    <xacro:wrist_refine_camera parent="gripper_base"/>
  </xacro:if>

  <ros2_control name="gripper_and_wheel_visuals" type="system">
    <hardware>
      <plugin>gazebo_ros2_control/GazeboSystem</plugin>
    </hardware>
    <joint name="gripper_left_finger_joint">
      <command_interface name="position"/>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="gripper_right_finger_joint">
      <command_interface name="position"/>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="wheel_fl_joint">
      <command_interface name="velocity"/>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="wheel_fr_joint">
      <command_interface name="velocity"/>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="wheel_rl_joint">
      <command_interface name="velocity"/>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="wheel_rr_joint">
      <command_interface name="velocity"/>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
  </ros2_control>

  <!-- ===== gazebo_ros2_control 插件(驱动 UR 关节) ===== -->
  <gazebo>
    <plugin filename="libgazebo_ros2_control.so" name="gazebo_ros2_control">
      <parameters>$(arg simulation_controllers)</parameters>
    </plugin>
  </gazebo>

  <gazebo>
    <plugin name="lab_cobot_mecanum_traction" filename="liblab_cobot_mecanum_drive.so">
      <control_mode>pose_from_wheel_commands</control_mode>
      <wheel_command_topic>/wheel_velocity_controller/commands</wheel_command_topic>
      <base_link>base_link</base_link>
      <wheel_joint>wheel_fl_joint</wheel_joint>
      <wheel_joint>wheel_fr_joint</wheel_joint>
      <wheel_joint>wheel_rl_joint</wheel_joint>
      <wheel_joint>wheel_rr_joint</wheel_joint>
      <wheel_radius>${wheel_radius}</wheel_radius>
      <wheelbase_radius>${base_length/2.0 - wheel_radius + base_width/2.0 + wheel_width/2.0}</wheelbase_radius>
      <linear_gain>14.0</linear_gain>
      <angular_gain>24.0</angular_gain>
      <max_force>2600.0</max_force>
      <max_torque>1400.0</max_torque>
      <max_linear_speed>0.45</max_linear_speed>
      <max_angular_speed>0.9</max_angular_speed>
      <max_linear_accel>0.8</max_linear_accel>
      <max_angular_accel>1.5</max_angular_accel>
      <publish_odom>true</publish_odom>
      <odom_topic>/odom</odom_topic>
      <odom_frame>odom</odom_frame>
      <base_frame>base_footprint</base_frame>
      <odom_rate>20.0</odom_rate>
    </plugin>
  </gazebo>

  <gazebo>
    <plugin name="lab_cobot_grasp_fix" filename="liblab_cobot_grasp_fix.so">
      <object_model>aruco_sample</object_model>
      <object_link>link</object_link>
      <tcp_link>gripper_tcp</tcp_link>
      <left_joint>gripper_left_finger_joint</left_joint>
      <right_joint>gripper_right_finger_joint</right_joint>
      <stable_attach_link>ur_wrist_3_link</stable_attach_link>
      <close_threshold>0.003</close_threshold>
      <release_threshold>0.003</release_threshold>
      <grip_count_threshold>1</grip_count_threshold>
      <require_finger_contact>$(arg require_finger_contact)</require_finger_contact>
      <enable_contact_force>$(arg enable_contact_force)</enable_contact_force>
      <!-- 稳定 A→B 默认使用非侵入式虚拟指尖力传感器:输出力曲线,
           但不启用物理 probe 接触响应,避免把样块顶飞。 -->
      <virtual_force_sensor>true</virtual_force_sensor>
      <virtual_force_stiffness>4500.0</virtual_force_stiffness>
      <virtual_force_baseline>0.3</virtual_force_baseline>
      <virtual_force_max>20.0</virtual_force_max>
      <contact_count_threshold>1</contact_count_threshold>
      <!-- grasp candidate is measured from stable_attach_link=ur_wrist_3_link.
           The gripper TCP sits about 135 mm above that link in this model, so
           the old TCP-based 90 mm envelope rejected a correctly aligned pick. -->
      <max_center_distance>0.220</max_center_distance>
      <max_abs_x>0.125</max_abs_x>
      <max_abs_y>0.105</max_abs_y>
      <min_z>-0.060</min_z>
      <max_z>0.220</max_z>
      <grasp_center_offset>-0.037 0.0 0.030</grasp_center_offset>
      <!-- 约束力保险丝保持默认禁用(0):位姿驱动底盘下正常搬运的
           fixed-joint ERP 校正力与压桌异常力同量级,阈值不可分离
           (实测启用会把物块半路丢掉)。压桌爆炸由 place 悬空释放
           (PLACE_RELEASE_CLEARANCE)机制性根治。 -->
    </plugin>
  </gazebo>

</robot>
