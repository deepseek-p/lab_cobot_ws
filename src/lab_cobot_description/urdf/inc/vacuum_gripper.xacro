<?xml version="1.0"?>
<!--
  真空吸盘末端:挂在 UR tool0 上,作为吸附作用点(suction_link)。
  实际抓取通过 Gazebo link attacher service 在运行时 attach/detach 物体模型,
  故 URDF 侧只需提供吸盘几何与坐标系。阶段2 可替换为平行夹爪。
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:macro name="vacuum_gripper" params="parent">
    <link name="suction_link">
      <visual>
        <origin xyz="0 0 0.02" rpy="0 0 0"/>
        <geometry><cylinder radius="0.025" length="0.04"/></geometry>
        <material name="suction_red"><color rgba="0.70 0.10 0.10 1.0"/></material>
      </visual>
      <collision>
        <origin xyz="0 0 0.02" rpy="0 0 0"/>
        <geometry><cylinder radius="0.025" length="0.04"/></geometry>
      </collision>
      <inertial>
        <mass value="0.1"/>
        <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
      </inertial>
    </link>
    <joint name="suction_joint" type="fixed">
      <parent link="${parent}"/>
      <child link="suction_link"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>
    <gazebo reference="suction_joint">
      <preserveFixedJoint>true</preserveFixedJoint>
    </gazebo>
    <!-- 吸附作用点(TCP 末端) -->
    <link name="grasp_point"/>
    <joint name="grasp_point_joint" type="fixed">
      <parent link="suction_link"/>
      <child link="grasp_point"/>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
    </joint>
    <gazebo reference="suction_link">
      <material>Gazebo/Red</material>
      <preserveFixedJoint>true</preserveFixedJoint>
    </gazebo>

    <!-- 真空吸盘插件:service /suction/switch(std_srvs/SetBool)开关,
         topic /suction/grasping(std_msgs/Bool)状态。max_distance 内的非 fixed 物体被吸附。 -->
    <gazebo>
      <plugin name="vacuum_gripper" filename="libgazebo_ros_vacuum_gripper.so">
        <ros>
          <namespace>/</namespace>
          <remapping>switch:=suction/switch</remapping>
          <remapping>grasping:=suction/grasping</remapping>
        </ros>
        <link_name>ur_wrist_3_link</link_name>
        <max_distance>0.06</max_distance>
        <fixed>ground_plane</fixed>
        <fixed>walls</fixed>
        <fixed>station_a_table</fixed>
        <fixed>station_b_table</fixed>
      </plugin>
    </gazebo>
  </xacro:macro>

</robot>
