<?xml version="1.0"?>
<!--
  传感器:2D LiDAR(/scan)+ IMU(/imu/data)+ RGB-D 相机(/bench_camera/*)。
  用标准 Gazebo Classic 插件(gazebo_ros_ray_sensor / imu_sensor / camera)。
  依赖全局 property: base_length, base_width, base_height
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:macro name="lab_sensors">

    <!-- ===== 2D LiDAR(底盘前方顶部) ===== -->
    <link name="laser">
      <visual>
        <geometry><cylinder radius="0.03" length="0.04"/></geometry>
        <material name="laser_black"><color rgba="0.05 0.05 0.05 1.0"/></material>
      </visual>
      <collision><geometry><cylinder radius="0.03" length="0.04"/></geometry></collision>
      <xacro:cylinder_inertia m="0.1" r="0.03" l="0.04"/>
    </link>
    <joint name="laser_joint" type="fixed">
      <parent link="base_link"/>
      <child link="laser"/>
      <origin xyz="${base_length/2.0 - 0.05} 0 ${base_height/2.0 + 0.04}" rpy="0 0 0"/>
    </joint>
    <gazebo reference="laser">
      <material>Gazebo/Black</material>
      <sensor type="ray" name="lidar">
        <pose>0 0 0 0 0 0</pose>
        <visualize>false</visualize>
        <always_on>true</always_on>
        <update_rate>10</update_rate>
        <ray>
          <scan><horizontal>
            <samples>360</samples><resolution>1</resolution>
            <min_angle>-3.14159</min_angle><max_angle>3.14159</max_angle>
          </horizontal></scan>
          <!-- min 0.32:立柱与激光同高、在其后方 0.165~0.291m 处,360°会扫到自身立柱,
               导致建图随机器人移动留下大量假障碍(594噪点簇)、导航 local costmap 误避障。
               提高最小量程使立柱落入盲区被忽略,同时保留 360° 感知(优于裁剪扫描角)。 -->
          <range><min>0.32</min><max>12.0</max><resolution>0.01</resolution></range>
        </ray>
        <plugin name="lidar_plugin" filename="libgazebo_ros_ray_sensor.so">
          <ros><namespace>/</namespace><remapping>~/out:=scan</remapping></ros>
          <output_type>sensor_msgs/LaserScan</output_type>
          <frame_name>laser</frame_name>
        </plugin>
      </sensor>
    </gazebo>

    <!-- ===== IMU(底盘中心) ===== -->
    <link name="imu_link">
      <visual><geometry><box size="0.02 0.015 0.008"/></geometry></visual>
      <xacro:box_inertia m="0.01" x="0.02" y="0.015" z="0.008"/>
    </link>
    <joint name="imu_joint" type="fixed">
      <parent link="base_link"/>
      <child link="imu_link"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>
    <gazebo reference="imu_link">
      <sensor name="imu_sensor" type="imu">
        <always_on>true</always_on>
        <update_rate>100</update_rate>
        <plugin name="imu_plugin" filename="libgazebo_ros_imu_sensor.so">
          <ros><namespace>/</namespace><remapping>~/out:=imu/data</remapping></ros>
          <frame_name>imu_link</frame_name>
          <initial_orientation_as_reference>false</initial_orientation_as_reference>
        </plugin>
      </sensor>
    </gazebo>

    <!-- ===== RGB-D 相机(立柱前上方,俯视前方工作台) ===== -->
    <link name="camera_link">
      <visual><geometry><box size="0.03 0.09 0.025"/></geometry>
        <material name="cam_dark"><color rgba="0.1 0.1 0.1 1"/></material></visual>
      <xacro:box_inertia m="0.05" x="0.03" y="0.09" z="0.025"/>
    </link>
    <!-- 装在立柱上方侧前方，避开 UR 基座自遮挡并俯视 station_a 样件 -->
    <joint name="camera_joint" type="fixed">
      <parent link="arm_mount_link"/>
      <child link="camera_link"/>
      <origin xyz="0.18 -0.22 0.85" rpy="0 0.65 0"/>
    </joint>
    <!-- 光学系(REP-103:z 向前,x 向右,y 向下) -->
    <link name="camera_optical_frame"/>
    <joint name="camera_optical_joint" type="fixed">
      <parent link="camera_link"/>
      <child link="camera_optical_frame"/>
      <origin xyz="0 0 0" rpy="${-pi/2.0} 0 ${-pi/2.0}"/>
    </joint>
    <gazebo reference="camera_link">
      <sensor name="rgbd_camera" type="depth">
        <always_on>true</always_on>
        <update_rate>15</update_rate>
        <camera>
          <horizontal_fov>1.047</horizontal_fov>
          <image><width>640</width><height>480</height><format>R8G8B8</format></image>
          <clip><near>0.05</near><far>3.0</far></clip>
        </camera>
        <plugin name="camera_plugin" filename="libgazebo_ros_camera.so">
          <ros><namespace>/</namespace></ros>
          <camera_name>bench_camera</camera_name>
          <frame_name>camera_optical_frame</frame_name>
          <min_depth>0.05</min_depth>
          <max_depth>3.0</max_depth>
        </plugin>
      </sensor>
    </gazebo>

  </xacro:macro>

</robot>
