<?xml version="1.0"?>
<!--
  麦克纳姆全向底盘(纯几何,不依赖外部 mesh)。
  车体运动来自 wheel_velocity_controller 轮速命令,再由
  lab_cobot_mecanum_drive pose_from_wheel_commands 按麦轮正解
  做有界位姿积分并逐 tick SetWorldPose 推进底盘。
  该模型不声称 Gazebo Classic 中的麦轮滚子接触物理真实:
  已移除 gazebo_ros_planar_move,但默认推进仍是位姿驱动
  (非力/速度级物理,底盘不受碰撞阻挡);轮碰撞经 collide_bitmask
  0x00 禁用,下方滚子摩擦参数为预留配置,当前不生效。
  依赖顶层定义的全局 property: base_length, base_width, base_height, wheel_radius, wheel_width
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:macro name="mecanum_base" params="base_mass:=40.0 publish_odom_tf:=false">

    <xacro:property name="wx" value="${base_length/2.0 - wheel_radius}"/>
    <xacro:property name="wy" value="${base_width/2.0 + wheel_width/2.0}"/>
    <xacro:property name="base_z" value="${wheel_radius + base_height/2.0}"/>

    <!-- 运动学根:底盘地面投影 -->
    <link name="base_footprint"/>

    <!-- 车体 -->
    <link name="base_link">
      <visual>
        <geometry><box size="${base_length} ${base_width} ${base_height}"/></geometry>
        <material name="base_blue"><color rgba="0.20 0.30 0.60 1.0"/></material>
      </visual>
      <collision>
        <geometry><box size="${base_length} ${base_width} ${base_height}"/></geometry>
      </collision>
      <collision name="base_ground_support">
        <origin xyz="0 0 ${-base_z + 0.01}" rpy="0 0 0"/>
        <geometry><box size="${base_length} ${base_width} 0.02"/></geometry>
      </collision>
      <xacro:box_inertia m="${base_mass}" x="${base_length}" y="${base_width}" z="${base_height}"/>
    </link>
    <joint name="base_footprint_joint" type="fixed">
      <parent link="base_footprint"/>
      <child link="base_link"/>
      <origin xyz="0 0 ${base_z}" rpy="0 0 0"/>
    </joint>

    <!-- 4 个麦轮:简化圆柱碰撞 + 视觉滚子条纹 -->
    <xacro:macro name="mec_wheel" params="name x y roller_slant">
      <link name="${name}">
        <visual>
          <origin xyz="0 0 0" rpy="${pi/2.0} 0 0"/>
          <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
          <material name="wheel_dark"><color rgba="0.10 0.10 0.10 1.0"/></material>
        </visual>
        <collision>
          <origin xyz="0 0 0" rpy="${pi/2.0} 0 0"/>
          <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
        </collision>
        <!-- Side-face roller strips make the wheels read as mecanum in Gazebo/RViz. -->
        <visual name="${name}_roller_outer_0">
          <origin xyz="0 ${wheel_width/2.0 + 0.003} ${-wheel_radius*0.46}" rpy="0 ${roller_slant*pi/4.0} 0"/>
          <geometry><box size="${wheel_radius*1.45} 0.006 0.012"/></geometry>
          <material name="roller_light"><color rgba="0.62 0.66 0.68 1.0"/></material>
        </visual>
        <visual name="${name}_roller_outer_1">
          <origin xyz="0 ${wheel_width/2.0 + 0.003} ${-wheel_radius*0.23}" rpy="0 ${roller_slant*pi/4.0} 0"/>
          <geometry><box size="${wheel_radius*1.45} 0.006 0.012"/></geometry>
          <material name="roller_light"><color rgba="0.62 0.66 0.68 1.0"/></material>
        </visual>
        <visual name="${name}_roller_outer_2">
          <origin xyz="0 ${wheel_width/2.0 + 0.003} 0" rpy="0 ${roller_slant*pi/4.0} 0"/>
          <geometry><box size="${wheel_radius*1.45} 0.006 0.012"/></geometry>
          <material name="roller_light"><color rgba="0.62 0.66 0.68 1.0"/></material>
        </visual>
        <visual name="${name}_roller_outer_3">
          <origin xyz="0 ${wheel_width/2.0 + 0.003} ${wheel_radius*0.23}" rpy="0 ${roller_slant*pi/4.0} 0"/>
          <geometry><box size="${wheel_radius*1.45} 0.006 0.012"/></geometry>
          <material name="roller_light"><color rgba="0.62 0.66 0.68 1.0"/></material>
        </visual>
        <visual name="${name}_roller_outer_4">
          <origin xyz="0 ${wheel_width/2.0 + 0.003} ${wheel_radius*0.46}" rpy="0 ${roller_slant*pi/4.0} 0"/>
          <geometry><box size="${wheel_radius*1.45} 0.006 0.012"/></geometry>
          <material name="roller_light"><color rgba="0.62 0.66 0.68 1.0"/></material>
        </visual>
        <visual name="${name}_roller_inner_0">
          <origin xyz="0 ${-(wheel_width/2.0 + 0.003)} ${-wheel_radius*0.46}" rpy="0 ${roller_slant*pi/4.0} 0"/>
          <geometry><box size="${wheel_radius*1.45} 0.006 0.012"/></geometry>
          <material name="roller_light"><color rgba="0.62 0.66 0.68 1.0"/></material>
        </visual>
        <visual name="${name}_roller_inner_1">
          <origin xyz="0 ${-(wheel_width/2.0 + 0.003)} ${-wheel_radius*0.23}" rpy="0 ${roller_slant*pi/4.0} 0"/>
          <geometry><box size="${wheel_radius*1.45} 0.006 0.012"/></geometry>
          <material name="roller_light"><color rgba="0.62 0.66 0.68 1.0"/></material>
        </visual>
        <visual name="${name}_roller_inner_2">
          <origin xyz="0 ${-(wheel_width/2.0 + 0.003)} 0" rpy="0 ${roller_slant*pi/4.0} 0"/>
          <geometry><box size="${wheel_radius*1.45} 0.006 0.012"/></geometry>
          <material name="roller_light"><color rgba="0.62 0.66 0.68 1.0"/></material>
        </visual>
        <visual name="${name}_roller_inner_3">
          <origin xyz="0 ${-(wheel_width/2.0 + 0.003)} ${wheel_radius*0.23}" rpy="0 ${roller_slant*pi/4.0} 0"/>
          <geometry><box size="${wheel_radius*1.45} 0.006 0.012"/></geometry>
          <material name="roller_light"><color rgba="0.62 0.66 0.68 1.0"/></material>
        </visual>
        <visual name="${name}_roller_inner_4">
          <origin xyz="0 ${-(wheel_width/2.0 + 0.003)} ${wheel_radius*0.46}" rpy="0 ${roller_slant*pi/4.0} 0"/>
          <geometry><box size="${wheel_radius*1.45} 0.006 0.012"/></geometry>
          <material name="roller_light"><color rgba="0.62 0.66 0.68 1.0"/></material>
        </visual>
        <xacro:cylinder_inertia m="1.2" r="${wheel_radius}" l="${wheel_width}"/>
      </link>
      <joint name="${name}_joint" type="continuous">
        <parent link="base_link"/>
        <child link="${name}"/>
        <origin xyz="${x} ${y} ${-base_height/2.0}" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
      </joint>
      <gazebo reference="${name}">
        <material>Gazebo/FlatBlack</material>
        <collide_bitmask>0x00</collide_bitmask>
        <mu1>1.0</mu1>
        <mu2>0.02</mu2>
        <fdir1>${cos(roller_slant*pi/4.0)} ${sin(roller_slant*pi/4.0)} 0</fdir1>
        <kp>1000000.0</kp>
        <kd>100.0</kd>
        <maxVel>0.1</maxVel>
        <minDepth>0.001</minDepth>
      </gazebo>
    </xacro:macro>

    <xacro:mec_wheel name="wheel_fl" x="${wx}"  y="${wy}"  roller_slant="1"/>
    <xacro:mec_wheel name="wheel_fr" x="${wx}"  y="${-wy}" roller_slant="-1"/>
    <xacro:mec_wheel name="wheel_rl" x="${-wx}" y="${wy}"  roller_slant="-1"/>
    <xacro:mec_wheel name="wheel_rr" x="${-wx}" y="${-wy}" roller_slant="1"/>

    <gazebo reference="base_link"><material>Gazebo/Blue</material></gazebo>
  </xacro:macro>

</robot>
