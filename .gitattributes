# 强制所有文本文件在仓库中以 LF 存储
* text=auto

# Python / shell / launch 文件必须在工作树保持 LF（WSL/Linux 运行需要）
*.py text eol=lf
*.sh text eol=lf
*.bash text eol=lf
*.launch.py text eol=lf

# C++ 源码
*.cpp text eol=lf
*.hpp text eol=lf
*.h text eol=lf
*.c text eol=lf
CMakeLists.txt text eol=lf
*.cmake text eol=lf

# 配置与标记文件
*.yaml text eol=lf
*.yml text eol=lf
*.xml text eol=lf
*.xacro text eol=lf
*.urdf text eol=lf
*.srdf text eol=lf
*.rviz text eol=lf
*.md text eol=lf
*.rst text eol=lf
